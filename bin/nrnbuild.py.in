#!/usr/bin/env python
"""
Compile mechanisms for NEURON

First .mod files are translated into C++ using either nocmodl or the
nmodl-transpiler. Then they are compiled and linked, and the resulting
library and executable are written to the current working directory.
"""
from argparse import ArgumentParser, RawDescriptionHelpFormatter
from find_libpython import find_libpython
from pathlib import Path
from subprocess import run
import os
import platform
import shutil
import sys

parser = ArgumentParser(description=__doc__, formatter_class=RawDescriptionHelpFormatter)

parser.add_argument("-v", "--verbose", action="store_true",
    help="show diagnostics")

parser.add_argument("-g", "--debug", action="store_true",
    help="compile in debug mode instead of release mode")

parser.add_argument("--clean", action="store_true",
    help="remove the build cache before starting")

parser.add_argument("-j", "--parallel", nargs="?", type=int, const=True, default=None,
    help="use multiple CPU cores for faster compilation")

parser.add_argument("--nmodl", action="store_true",
    help="use the new NMODL transpiler instead of nocmodl")

parser.add_argument("--nmodl_args", type=str,
    help="additional arguments for NMODL for NEURON codegen")

parser.add_argument("--coreneuron", action="store_true",
    help="compile MOD files for CoreNEURON")

parser.add_argument("--coreneuron_args", type=str,
    help="additional arguments for NMODL for CoreNEURON codegen")

parser.add_argument("--library_type", choices=["static", "shared"], default="shared",
    help="default: shared")

parser.add_argument("input_paths", nargs="*",
    metavar="MOD_FILES_AND_DIRECTORIES",
    help="default: current working directory")

args = parser.parse_args()
env = os.environ.copy()
arch = platform.machine()

# Get the name and location of the current program
program_path = Path(sys.argv[0]).resolve(strict=True)
program_name = program_path.name
program_dir  = program_path.parent
program_root = program_dir.parent # root (aka prefix) of installation

def print(text):
    __builtins__.print(f"[{program_name}] {text}", flush=True)

def warning(text):
    __builtins__.print(f"[{program_name}] WARNING: {text}", file=sys.stderr, flush=True)

def error(text, code):
    __builtins__.print(f"[{program_name}] ERROR: {text}", file=sys.stderr, flush=True)
    exit(code)

# Setup neuron's environment variables, while checking for user overrides
if "NRNHOME" in env:
    prefix      = Path(env["NRNHOME"])
    exec_prefix = prefix / arch
    bindir      = prefix / "bin"
    libdir      = prefix / "lib"
else:
    prefix      = Path("@prefix@")
    exec_prefix = Path("@exec_prefix@")
    bindir      = Path("@bindir@")
    libdir      = Path("@libdir@")

if "NRNHOME_EXEC" in env:
    exec_prefix = Path(env["NRNHOME_EXEC"])
    bindir      = exec_prefix / "bin"
    libdir      = exec_prefix / "lib"

env["prefix"] = prefix
env["bindir"] = bindir
env["libdir"] = libdir

# Setup coreneuron's install root
if "CORENRNHOME" in env:
    cnrn_prefix = Path(env["CORENRNHOME"])
else:
    # Fallback to this program's install root, since they are shipped together
    cnrn_prefix = program_root

# Set the install root for the NMODL project
if "NMODLHOME" not in env:
    env["NMODLHOME"] = program_root

# Search for libpython.so/dll, for the NMODL transpiler to embed
env["NMODL_PYLIB"] = libpython = find_libpython()
if not libpython:
    error("unable to locate libpython, please make sure to install the development version of python", 3)

# On MacOS we need to set the deployment target to be equal to the one of NEURON
if shutil.which("xcrun") is not None:
    OSX_BUILD = "@NRN_OSX_BUILD_TRUE@" != "#"
    if OSX_BUILD:
        env["SDKROOT"] = subprocess.run(["xcrun", "--sdk", "macosx", "--show-sdk-path"],
                    check=True,
                    text=True,
                    capture_output=True
                    ).stdout.strip()
        env["MACOSX_DEPLOYMENT_TARGET"] = "@CMAKE_OSX_DEPLOYMENT_TARGET@"
    if not "@CMAKE_OSX_DEPLOYMENT_TARGET@":
        del env["MACOSX_DEPLOYMENT_TARGET"]

# Find where the `*.cmake` files are located
nrn_cmake_prefix_default = program_root.joinpath("lib").joinpath("cmake")
if "CMAKE_PREFIX_PATH" in env:
    env["CMAKE_PREFIX_PATH"] += ":" + nrn_cmake_prefix_default
else:
    env["CMAKE_PREFIX_PATH"] = nrn_cmake_prefix_default

# Where the "CMakeLists.txt" file is installed to
src_dir = nrn_cmake_prefix_default.joinpath("neuron").joinpath("nrnbuild")

# Where the output files will be placed
bin_dir = Path.cwd() / arch

if args.clean and bin_dir.exists():
    if args.verbose:
        print(f"Removing build cache: {bin_dir}")
    shutil.rmtree(bin_dir)

# Collect up the nmodl files.
input_paths = [Path(path) for path in args.input_paths]

# Convert all paths to absolute to avoid the user's current working directory.
for i in range(len(input_paths)):
    input_paths[i] = path = input_paths[i].resolve()
    # Check all paths exist.
    if not path.exists():
        error(f"No such file or directory: \"{path}\"", 1)

# In case of no files, default to using the files in the current dir
if not input_paths:
    print(f"Collecting mod files from current directory: {Path.cwd()}")
    mod_files = sorted(Path.cwd().glob("*.mod"))

else:
    mod_files = []
    for path in input_paths:
        # Check for directories
        if path.is_dir():
            print(f"Collecting mod files from directory: {path}")
            mod_files.extend(sorted(path.glob("*.mod")))

        elif path.suffix == '.mod':
            mod_files.append(path)

        else:
            error(f"not a .mod file: \"{path}\"", 2)

if not mod_files:
    warning("No .mod files found, exiting")
    exit(0)

print("Found mod files: " + ' '.join(str(path.name) for path in mod_files))

# Configure the cmake project
def cmake_bool(arg):
    return "ON" if arg else "OFF"
mod_files_str = ";".join(str(path) for path in mod_files)
config_command = [
    "cmake",
    "-S",
    str(src_dir),
    "-B",
    str(bin_dir),
    "-DNRNBUILD_MOD_FILES=" + mod_files_str,
    "-DLIBRARY_TYPE=" + args.library_type.upper(),
    "-DNRNBUILD_CORENEURON=" + cmake_bool(args.coreneuron),
    "-DNRNBUILD_NMODL=" + cmake_bool(args.nmodl),
]
if args.debug:
    config_command.append('-DCMAKE_BUILD_TYPE=Debug')
if args.nmodl_args:
    config_command.append(f'-DNRNBUILD_NMODL_ARGS={args.nmodl_args}')
if args.coreneuron_args:
    config_command.append(f'-DNRNBUILD_CORENEURON_ARGS={args.coreneuron_args}')
if args.verbose:
    config_command.append("--log-level=VERBOSE")
    print(' '.join(config_command))
run(config_command, env=env, check=True)

# Process and compile the mod files
build_command = ["cmake", "--build", str(bin_dir)]
if args.debug:
    build_command.extend(("--config", "Debug"))
if args.parallel:
    if args.parallel is True:
        build_command.append("--parallel")
    else:
        build_command.extend(("--parallel", str(args.parallel)))
if args.verbose:
    build_command.append("--verbose")
    if args.nmodl:
        print(f"NMODLHOME={program_root}")
        print(f"NMODL_PYLIB={libpython}")
    print(' '.join(build_command))
run(build_command, env=env, check=True)
